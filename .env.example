# AES-256-GCM encryption key (32 hex bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
AES_KEY=your_64_hex_char_key_here

# Root directory for all file operations
WORKSPACE_ROOT=../..

# MCP Server port
PORT=3100

# Admin password for license key management dashboard
ADMIN_PASSWORD=change_this_password

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
